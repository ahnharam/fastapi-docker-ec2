{
  "info": {
    "_postman_id": "b429bf83-5f2a-4f8c-9c3d-8a7ad47a74b9",
    "name": "FastAPI Docker EC2",
    "description": "실습 5 Courses API의 GET, POST, validation 요청 모음입니다.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "GET courses",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/courses",
          "host": ["{{base_url}}"],
          "path": ["courses"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "pm.test('response is a list', () => pm.expect(pm.response.json()).to.be.an('array'));"
            ]
          }
        }
      ]
    },
    {
      "name": "POST course",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"course_name\": \"Docker 컨테이너 실습\",\n  \"year\": \"2026\",\n  \"semester\": \"여름학기\",\n  \"grade\": \"P\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/courses",
          "host": ["{{base_url}}"],
          "path": ["courses"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 201', () => pm.response.to.have.status(201));",
              "pm.test('request object is returned', () => pm.expect(pm.response.json()).to.eql(JSON.parse(pm.request.body.raw)));"
            ]
          }
        }
      ]
    },
    {
      "name": "POST invalid course",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"course_name\": \"\",\n  \"year\": \"2026\",\n  \"semester\": \"1학기\",\n  \"grade\": \"A+\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/courses",
          "host": ["{{base_url}}"],
          "path": ["courses"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('invalid body returns 422', () => pm.response.to.have.status(422));"
            ]
          }
        }
      ]
    }
  ]
}
